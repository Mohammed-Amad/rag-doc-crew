# Free option (default) - get a key at https://console.groq.com/keys
# Used for the agent LLM (the 3 agents' reasoning).
GROQ_API_KEY=your-groq-key-here

# Embeddings run 100% locally by default (no key needed, no region
# restriction) via ChromaDB's built-in model. Nothing to set for this.

# --- OR, to use Gemini instead of Groq for the LLM ---
# (Google's free tier is region-restricted; if you hit a 429 with
# "limit: 0", it means your account's country isn't supported, not that
# you used up a quota.)
# GEMINI_API_KEY=your-gemini-key-here

# --- OR, to use OpenAI instead ---
# OPENAI_API_KEY=your-openai-key-here
