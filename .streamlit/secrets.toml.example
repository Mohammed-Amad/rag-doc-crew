# For LOCAL testing only: copy this file to .streamlit/secrets.toml and fill
# in your key. .streamlit/secrets.toml should NOT be committed to git.
#
# For DEPLOYMENT on Streamlit Community Cloud: don't use this file at all --
# instead go to your app's Settings -> Secrets in the Streamlit Cloud
# dashboard and paste the same content there. Streamlit Cloud injects it
# automatically; you never upload secrets.toml itself.

GROQ_API_KEY = "your-groq-key-here"
